DOMAIN=meteo.example.com

# App runtime
NODE_ENV=production
HOST=0.0.0.0
APP_PORT=3600

# Database (use host MySQL via host.docker.internal)
MYSQL_EMBEDDED=false
MYSQL_EMBEDDED_VERSION=8.4.x
MYSQL_EMBEDDED_DBNAME=meteo_iot
MYSQL_EMBEDDED_PORT=3307
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=meteo_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=meteo_iot

# Optional frontend build-time overrides
VITE_API_BASE=/api
VITE_WS_URL=